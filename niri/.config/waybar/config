{
    "layer": "top",
    "position": "top",
    "height": 24,
    "margin-top": 6,
    "margin-left": 8,
    "margin-right": 8,
    "spacing": 0,
    "modules-left": [
        "custom/launcher",
        "niri/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "group/tray-expander",
        "idle_inhibitor",
        "backlight",
        "pulseaudio",
        "network",
        "battery",
        "custom/power"
    ],
    "custom/launcher": {
        "format": "´îâ",
        "on-click": "rofi -show drun -theme ~/.config/rofi/config.rasi",
        "tooltip": false
    },
    "niri/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "default": "¯®▒",
            "active": "¾▒ô╗"
        }
    },
    "clock": {
        "interval": 60,
